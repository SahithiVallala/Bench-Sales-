# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=resumes

# ── Google Gemini AI ───────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Job Search APIs ────────────────────────────────────────────
GOOGLE_CSE_API_KEY=your-google-cse-key-here
GOOGLE_CSE_ID=your-custom-search-engine-id

JSEARCH_API_KEY=your-rapidapi-key-here

# ── Groq AI (fallback when Gemini quota exceeded) ──────────────
# Get free key at: console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-70b-versatile

# ── Microsoft Outlook / Graph API (JD Inbox) ───────────────────
# Register an app at portal.azure.com → App registrations
# Add redirect URI: http://localhost:8000/api/email/callback
# Required permissions: Mail.Read, offline_access, User.Read
MS_CLIENT_ID=your_azure_app_client_id
MS_CLIENT_SECRET=your_azure_app_client_secret
MS_REDIRECT_URI=http://localhost:8000/api/email/callback

# ── App Config ─────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
